                var toggle = $(".pack-description-toggle");
                if(!body.length || !text.length || !toggle.length) {return;}
                if(text[0].scrollHeight <= body[0].clientHeight + 6) {
                    body.removeClass("is-collapsed");
                    toggle.hide();
                    return;
                }
                toggle.show().on("click", function(){
                    var expanded = body.toggleClass("is-expanded").hasClass("is-expanded");
                    body.toggleClass("is-collapsed", !expanded);
                    $(this).text(expanded ? "Show Less" : "Read More");
                });
